#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  # TEA-213: idempotently load the 41 specialty gap-list rows on each boot.
  # SpecialtyPriceLoaderService uses find_or_initialize_by + per-row rescue,
  # so reruns are safe and a failure here must not block server startup.
  ./bin/rails specialty_prices:load || echo "[specialty_prices:load] failed, continuing boot"
  # TEA-203: idempotently load Road B (Tavily + Haiku) web_search prices on each boot.
  # WebSearchPriceLoaderService uses find_or_initialize_by + per-row rescue,
  # so reruns are safe and a failure here must not block server startup.
  ./bin/rails web_search_prices:load || echo "[web_search_prices:load] failed, continuing boot"
  # TEA-236: sandbox-only fixture loader for the Test Estimate dashboard re-smoke.
  # Seeds one confidence=medium material_prices row and shared-material
  # default_pricings (corner_bead, screws on drywall+siding) so Commander's
  # 7-item smoke exercises the pending/range render path and multi-trade
  # dedup path. find_or_initialize_by + save! — idempotent, safe on every boot.
  # Lives in the entrypoint (not a one-shot rake) because the agent runtime
  # has no Railway CLI access. This is a SANDBOX FIXTURE, not production seed.
  ./bin/rails tea236:smoke_seeds || echo "[tea236:smoke_seeds] failed, continuing boot"
fi

exec "${@}"
